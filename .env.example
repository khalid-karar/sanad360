# ─────────────────────────────────────────────────────────────
# Tadweer360 – environment variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Supabase project credentials (Settings → API in the Supabase dashboard)
# For local dev use: supabase start  →  outputs these values
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional: only needed when running the immutability tests against a real DB ──
# Use the service_role key from: supabase status
# WARNING: this key bypasses RLS – never expose it to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Phase 2: PDF service (services/pdf) ──
# Local dev: run `npm run dev` in services/pdf — it listens on port 3001
VITE_PDF_SERVICE_URL=http://localhost:3001
