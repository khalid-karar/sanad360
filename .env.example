# ═════════════════════════════════════════════════════════════
# Sanad 360 – frontend + test environment variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# Environments are config-only (see DEPLOYMENT.md):
#   local      → supabase start (it prints these values)
#   staging    → the staging Supabase project's URL/keys
#   production → the Dammam/CNTXT project's URL/keys (CI-only, via
#                GitHub Environment secrets — never in a developer .env)
# ═════════════════════════════════════════════════════════════

# ── Frontend (safe to expose — bundled into the browser build) ──
# Supabase project URL + anon/publishable key.
# Local dev: `supabase start` prints these. Hosted: Settings → API.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Base URL of the PDF microservice (services/pdf). Local dev default: 3001.
VITE_PDF_SERVICE_URL=http://localhost:3001

# ── Tests only (server-side; bypasses RLS — never expose to the browser) ──
# service_role key, used exclusively by the vitest integration suite for
# setup/teardown. Local dev: `supabase status`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Migration promotion (scripts/db-target.mjs; usually CI-only) ──
# Personal/CI access token for the Supabase CLI (supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=sbp_...
# Project refs (Settings → General → Reference ID)
# SUPABASE_STAGING_PROJECT_REF=your-staging-ref
# SUPABASE_PROD_PROJECT_REF=your-prod-ref
# Database passwords (Settings → Database) — needed by `supabase db push`
# SUPABASE_STAGING_DB_PASSWORD=...
# SUPABASE_PROD_DB_PASSWORD=...
# STAGING seeding (production is NEVER seeded). From CI, set this to the
# SESSION POOLER connection string (Supabase dashboard -> Project Settings ->
# Database -> Connection string -> "Session pooler" tab) — GitHub Actions
# runners have no IPv6 egress, and Supabase's direct host (db.<ref>.supabase.co)
# is IPv6-only without the paid IPv4 add-on, so seeding from CI against the
# direct host fails to connect. If unset, scripts/db-target.mjs falls back to
# building the direct-host URL from the ref + password above (fine for local/
# manual use, not for CI). Percent-encode the password if you paste it in by hand.
# SUPABASE_STAGING_DB_URL=postgresql://postgres.<staging-ref>:...@aws-0-<region>.pooler.supabase.com:5432/postgres
