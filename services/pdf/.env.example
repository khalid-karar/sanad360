# ═════════════════════════════════════════════════════════════
# Sanad 360 – PDF service environment variables
# Copy to .env and fill in values. NEVER commit .env to git.
#
# The service also falls back to the repo-root .env (see src/lib/env.ts),
# accepting the VITE_-prefixed names, so in local dev one root .env is enough.
# ═════════════════════════════════════════════════════════════

# Supabase project URL (local: supabase start; hosted: Settings → API)
SUPABASE_URL=http://localhost:54321

# anon key — used ONLY to validate caller JWTs via auth.getUser()
SUPABASE_ANON_KEY=your-anon-key-here

# service_role key — bypasses RLS; powers DB reads + storage writes.
# Keep strictly server-side. Hosted: store in the host's secret manager.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HTTP port (default 3001)
PORT=3001

# Allowed browser origin (the frontend URL for this environment)
# local: http://localhost:5173 | staging/prod: the deployed frontend URL
CORS_ORIGIN=http://localhost:5173

# Optional: error tracking (no-op when unset)
SENTRY_DSN=
SENTRY_ENV=staging

# ── CP5.5: self-service signup + SES email (server-side only) ───────────────
# Frontend origin used to build the emailed verification link
# (${PUBLIC_APP_URL}/verify?token=...). NEVER the pdf-service's own URL.
PUBLIC_APP_URL=http://localhost:5173

# SES region (required to send email).
AWS_REGION=me-south-1

# Verified SES sender address/identity.
SES_FROM_EMAIL=noreply@example.com

# AWS credentials — optional. If unset, the AWS SDK's default provider chain
# falls back to an attached IAM role (ECS/EC2 task role) instead, which is
# the preferred approach in a real deployment. Set these only for local dev
# or hosts without an attachable role. Keep strictly server-side.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
